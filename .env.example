# ============================================
# 阿里云百炼配置
# ============================================
DASHSCOPE_API_KEY=REDACTED_API_KEY
DASHSCOPE_MODEL=qwen3-32b-14f1c635395e
DASHSCOPE_FINETUNED_MODEL=qwen3-32b-14f1c635395e

# AI 系统提示词
SYSTEM_PROMPT=

# ============================================
# 微信机器人配置
# ============================================

# 机器人名称，用于群聊中被 @ 时识别（必须带@）
BOT_NAME=@你的微信名

# 私聊联系人白名单 (逗号分隔，填写备注名或昵称)
ALIAS_WHITELIST=bot

# 群白名单 (逗号分隔，填写群名)
ROOM_WHITELIST=

# 自动回复前缀 (只有以此前缀开头的消息才触发，留空则全部回复)
AUTO_REPLY_PREFIX=

# 自动监听间隔（秒）
LISTEN_INTERVAL=1.0

# 是否启用自动回复
AUTO_REPLY_ENABLED=true

# ============================================
# 数据处理配置
# ============================================
DATA_SOURCE_DIR=./data/raw
DATA_OUTPUT_DIR=./data/processed
MIN_TRAIN_SAMPLES=500