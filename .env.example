# 阿里云百炼配置
DASHSCOPE_API_KEY=your-api-key-here
DASHSCOPE_MODEL=qwen-turbo
DASHSCOPE_FINETUNED_MODEL=your-finetuned-model-id

# 微信机器人配置
WECHAT_AUTO_REPLY=true
WECHAT_REPLY_PREFIX=
WECHAT_REPLY_SUFFIX=

# 数据处理配置
DATA_SOURCE_DIR=C:/Users/Administrator/Downloads/texts
DATA_OUTPUT_DIR=./data/processed
MIN_TRAIN_SAMPLES=500